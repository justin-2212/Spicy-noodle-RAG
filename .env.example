# Environment Configuration Template
# Copy this to .env and fill in your values

# FastAPI
FASTAPI_DEBUG=False
FASTAPI_PORT=8000
FASTAPI_HOST=0.0.0.0

# Database
DB_URL=postgresql://user:password@localhost:5432/food_db
DB_ECHO=False
DB_POOL_SIZE=10

# Vector Store (Qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=food_items

# Embedding Model
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=32
EMBEDDING_CACHE_DIR=./models/embeddings

# Reranker Model
RERANKER_MODEL_NAME=BAAI/bge-reranker-base
RERANKER_DEVICE=cuda
RERANKER_BATCH_SIZE=64
RERANKER_CACHE_DIR=./models/reranker

# LLM Provider
LLM_PROVIDER=groq
LLM_USE_FALLBACK=True
LLM_GEMINI_API_KEY=your-gemini-api-key-here
LLM_GEMINI_MODEL_NAME=gemini-1.5-flash
LLM_GROQ_API_KEY=your-groq-api-key-here
LLM_GROQ_MODEL_NAME=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# Retrieval Settings
RETRIEVAL_DENSE_TOP_K=20
RETRIEVAL_SPARSE_TOP_K=20
RETRIEVAL_HYBRID_TOP_K=10
RETRIEVAL_RERANK_TOP_K=5
RETRIEVAL_DENSE_WEIGHT=0.6
RETRIEVAL_SPARSE_WEIGHT=0.4

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
